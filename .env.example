# ─── Copy this to .env and adjust values ─────────────────────────────────────

# LLM
DEFAULT_MODEL=mistral
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT=120
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096

# API
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# Storage
DATABASE_URL=sqlite:///./ai_system.db
VECTOR_DB_PATH=./vector_db
VECTOR_COLLECTION_NAME=kairo_memory

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/ai_system.log

# Analysis thresholds
MIN_KEYWORD_SCORE=0.5
SIMILARITY_THRESHOLD=0.6

# Debug mode (enables SQL echo, auto-reload)
DEBUG=false
